[61.975212, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"objects_deleted\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m11\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
