[51.197053, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"query_id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"results\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n    \u001b[1;39m{\r\n      \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m2\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"score\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m1.0126972\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"vector\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m1.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m,\r\n        \u001b[0;39m0.0\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"text\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"a lazy dog sleeps quietly\"\u001b[0m\u001b[1;39m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m\r\n  \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
