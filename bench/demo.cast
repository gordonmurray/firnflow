[57.150336, "o", "# HELP firnflow_cache_hits_total Cache hits, keyed by namespace.\r\n# TYPE firnflow_cache_hits_total counter\r\nfirnflow_cache_hits_total{namespace=\"demo\"} 2\r\n# HELP firnflow_cache_misses_total Cache misses, keyed by namespace.\r\n# TYPE firnflow_cache_misses_total counter\r\nfirnflow_cache_misses_total{namespace=\"demo\"} 4\r\n"]
[57.15041, "o", "# HELP firnflow_s3_requests_total firnflow-initiated operations that bypassed the cache and would have issued S3 traffic. Counted at the service boundary (one per upsert, one per cache-miss query), not at raw `object_store` call granularity — this is the signal for 'did the cache save a round-trip', not a faithful count of HTTP requests to S3.\r\n# TYPE firnflow_s3_requests_total counter\r\nfirnflow_s3_requests_total{namespace=\"demo\",operation=\"delete\"} 1\r\nfirnflow_s3_requests_total{namespace=\"demo\",operation=\"fts_index\"} 1\r\nfirnflow_s3_requests_total{namespace=\"demo\",operation=\"query\"} 4\r\nfirnflow_s3_requests_total{namespace=\"demo\",operation=\"upsert\"} 2\r\n"]
[58.655742, "o", "\r\n  --- delete namespace ---\r\n"]
